{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_report.schema.json",
  "type": "object",
  "required": [
    "category_scores",
    "field_evidence_map",
    "calibration",
    "reviewer_panel_synthesis",
    "issues",
    "revision_actions",
    "evidence_ledger",
    "red_line_self_audit",
    "overall_recommendation"
  ],
  "properties": {
    "category_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "score.schema.json"
      }
    },
    "field_evidence_map": {
      "type": "array",
      "minItems": 1
    },
    "calibration": {
      "type": "object"
    },
    "reviewer_panel_synthesis": {
      "type": "object"
    },
    "external_scientific_skills_used": {
      "type": "array"
    },
    "mcp_capabilities_used": {
      "type": "array"
    },
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "issue.schema.json"
      }
    },
    "revision_actions": {
      "type": "array",
      "minItems": 1
    },
    "evidence_ledger": {
      "$ref": "evidence_ledger.schema.json"
    },
    "red_line_self_audit": {
      "type": "array",
      "minItems": 1
    },
    "overall_recommendation": {
      "enum": ["Accept", "Minor Revision", "Major Revision", "Reject"]
    }
  },
  "additionalProperties": true
}
