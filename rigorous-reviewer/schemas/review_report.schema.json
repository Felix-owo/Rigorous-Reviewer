{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RigorousReviewerReport",
  "type": "object",
  "required": [
    "executive_verdict",
    "central_claims",
    "issues",
    "final_recommendation"
  ],
  "properties": {
    "executive_verdict": {
      "type": "string",
      "minLength": 1
    },
    "central_claims": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "specific_problem",
          "decision_impact"
        ],
        "properties": {
          "severity": {
            "enum": [
              "Critical",
              "Major",
              "Minor",
              "Optimization"
            ]
          },
          "specific_problem": {
            "type": "string"
          },
          "decision_impact": {
            "type": "string"
          }
        }
      }
    },
    "final_recommendation": {
      "enum": [
        "Accept",
        "Minor Revision",
        "Major Revision",
        "Reject"
      ]
    }
  }
}
