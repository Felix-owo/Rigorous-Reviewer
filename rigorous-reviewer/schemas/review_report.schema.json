{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_report.schema.json",
  "type": "object",
  "required": [
    "category_scores",
    "pre_review_contract",
    "claim_maturity_gate",
    "field_evidence_map",
    "calibration",
    "reviewer_panel_synthesis",
    "issues",
    "revision_actions",
    "evidence_ledger",
    "red_line_self_audit",
    "overall_recommendation"
  ],
  "properties": {
    "category_scores": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "score.schema.json"
      }
    },
    "user_supplied_material_handling": {
      "type": "array"
    },
    "pre_review_contract": {
      "$ref": "review_contract.schema.json"
    },
    "phase_boundary_trace": {
      "type": "array"
    },
    "claim_maturity_gate": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "current_maturity",
          "evidence_basis",
          "blocking_loophole",
          "maturity_upgrade_readout",
          "required_narrowing"
        ],
        "additionalProperties": true,
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 2
          },
          "current_maturity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 3
          },
          "evidence_basis": {
            "type": "string",
            "minLength": 8
          },
          "blocking_loophole": {
            "type": "string",
            "minLength": 4
          },
          "maturity_upgrade_readout": {
            "type": "string",
            "minLength": 8
          },
          "required_narrowing": {
            "type": "string",
            "minLength": 4
          }
        }
      }
    },
    "claim_readout_handoff": {
      "$ref": "claim_readout_handoff.schema.json"
    },
    "field_evidence_map": {
      "type": "array",
      "minItems": 1
    },
    "assumption_ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "assumption",
          "source_or_absence",
          "possible_bias_direction",
          "updating_evidence"
        ],
        "additionalProperties": true,
        "properties": {
          "assumption": {
            "type": "string",
            "minLength": 8
          },
          "source_or_absence": {
            "type": "string",
            "minLength": 3
          },
          "possible_bias_direction": {
            "type": "string",
            "minLength": 4
          },
          "updating_evidence": {
            "type": "string",
            "minLength": 8
          }
        }
      }
    },
    "calibration": {
      "type": "object"
    },
    "reviewer_panel_synthesis": {
      "type": "object"
    },
    "figure_claim_audit": {
      "type": "array"
    },
    "external_scientific_skills_used": {
      "type": "array"
    },
    "external_companion_evidence": {
      "type": "array",
      "items": {
        "$ref": "external_companion_evidence.schema.json"
      }
    },
    "mcp_capabilities_used": {
      "type": "array"
    },
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "issue.schema.json"
      }
    },
    "revision_actions": {
      "type": "array",
      "minItems": 1
    },
    "review_to_revision_action_map": {
      "type": "array"
    },
    "evidence_ledger": {
      "$ref": "evidence_ledger.schema.json"
    },
    "red_line_self_audit": {
      "type": "array",
      "minItems": 1
    },
    "overall_recommendation": {
      "enum": [
        "Accept",
        "Minor Revision",
        "Major Revision",
        "Reject"
      ]
    }
  },
  "additionalProperties": true
}
